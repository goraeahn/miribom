# ============================================================================
# 미리봄(Miribom) 환경변수 예시
# ----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 .env 로 복사한다.   cp .env.example .env
#   2) 아래 값들을 실제 값으로 채운다.
#   3) .env 는 절대 커밋하지 않는다 (.gitignore 에 등록되어 있음).
#      저장소에는 이 .env.example 만 커밋한다.
#
# 값 위치: Supabase 대시보드 > Project Settings > API
# 참고: anon key 는 공개되어도 안전한 키다(RLS 로 데이터 보호). 다만 환경(개발/운영)
#       분리를 위해 코드에 박지 않고 환경변수로 둔다.
#       service_role 키는 RLS 를 우회하므로 절대 프런트엔드/깃에 노출 금지.
# ============================================================================

# 프로젝트 URL (예: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# 공개(anon) 키 — 프런트엔드에서 사용
SUPABASE_ANON_KEY=

# service_role 키 — 서버·관리 스크립트 전용. 절대 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# DB 연결 문자열 — Supabase CLI/psql 로 마이그레이션을 직접 적용할 때 사용(선택)
# 예: postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
SUPABASE_DB_URL=
